# Copy to .env and fill in what you need. Everything is optional:
# with no keys at all the API starts in keyless demo mode (canned responses).

# Which LLM backend to use: openai | anthropic | mock
# Leave empty to auto-detect: openai if OPENAI_API_KEY is set,
# else anthropic if ANTHROPIC_API_KEY is set, else mock.
LLM_PROVIDER=

# Model override. Defaults: gpt-4o-mini (openai), claude-haiku-4-5 (anthropic).
LLM_MODEL=

# Provider API keys. You only need the one for the provider you use.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Upstream request timeout in seconds and SDK retry count.
LLM_TIMEOUT_SECONDS=30
LLM_MAX_RETRIES=2
